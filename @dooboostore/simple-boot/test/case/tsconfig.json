{
  "compilerOptions": {
    "target": "es2019",
    "module": "esnext",
    "lib": ["es2019", "dom"],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "strict": false,
    "sourceMap": true,
    "moduleResolution": "node",
    "baseUrl": "./",
    "paths": {
      "@dooboostore/core": ["../../../core/src/index.ts"],
      "@dooboostore/core-node": ["../../../core-node/src/index.ts"],
      "@dooboostore/simple-boot": ["../../../simple-boot/src/index.ts"],
      "@dooboostore/simple-boot-http-server": ["../../../simple-boot-http-server/src/index.ts"],
      "@dooboostore/simple-boot-http-server-ssr": ["../../../simple-boot-http-server-ssr/src/index.ts"],
      "@dooboostore/simple-boot-front": ["../../../simple-boot-front/src/index.ts"],
      "@dooboostore/dom-render": ["../../../dom-render/src/index.ts"]
    }
  },
  "ts-node": {
    "esm": true,
    "experimentalEsm": true,
    "compilerOptions": {
      "module": "esnext",
      "experimentalDecorators": true,
      "emitDecoratorMetadata": true,
      "strict": false
    }
  }
}
