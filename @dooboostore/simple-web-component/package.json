{
  "name": "@dooboostore/simple-web-component",
  "version": "1.0.32",
  "license": "MIT",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "typesVersions": {
    "*": {
      "*": [
        "dist/types/*"
      ]
    }
  },
  "description": "Simple Web Component library based on dom-render philosophy",
  "sideEffects": [
    "./dist/esm/elements/*.js",
    "./dist/esm/elements/is/*.js",
    "./dist/cjs/elements/*.js",
    "./dist/cjs/elements/is/*.js",
    "*.ts"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dooboostore-develop/packages.git",
    "directory": "packages/@dooboostore/simple-web-component"
  },
  "bugs": {
    "url": "https://github.com/dooboostore-develop/packages/issues"
  },
  "homepage": "https://github.com/dooboostore-develop/packages/tree/main/%40dooboostore/simple-web-component",
  "keywords": [
    "front",
    "web-components",
    "view",
    "template",
    "simple-web-component",
    "front-end"
  ],
  "files": [
    "dist",
    "src",
    "types.d.ts",
    "LICENSE.md",
    "tsconfig.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./bundle-entry": {
      "types": "./dist/types/bundle-entry.d.ts",
      "import": "./dist/esm/bundle-entry.js",
      "require": "./dist/cjs/bundle-entry.js"
    },
    "./*": {
      "types": "./dist/types/*.d.ts",
      "import": "./dist/esm/*.js",
      "require": "./dist/cjs/*.js"
    }
  },
  "author": "dooboostore <dooboostore@gmail.com> (https://github.com/dooboostore)",
  "peerDependencies": {
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-proposal-decorators": "^7.24.0",
    "@babel/plugin-transform-private-property-in-object": "^7.25.9",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-typescript": "^7.24.0",
    "@dooboostore/core": "workspace:*",
    "@dooboostore/core-node": "workspace:*",
    "@dooboostore/core-web": "workspace:*",
    "@dooboostore/simple-boot": "workspace:*",
    "@types/jest": "^26.0.22",
    "@types/node": "^20",
    "@typescript-eslint/eslint-plugin": "^4.16.1",
    "@typescript-eslint/parser": "^4.16.1",
    "esbuild": "^0.23.0",
    "esbuild-plugin-tsc": "^0.5.0",
    "html-webpack-plugin": "^5.6.3",
    "raw-loader": "^4.0.2",
    "reflect-metadata": "^0.2.2",
    "ts-loader": "^9.5.1",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2",
    "webpack": "^5.93.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.2.0"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build:esm": "node build.mjs esm",
    "watch:esm": "pnpm run build:esm && node build.mjs esm --watch",
    "build:cjs": "node build.mjs cjs",
    "watch:cjs": "pnpm run build:cjs && node build.mjs cjs --watch",
    "build": "pnpm run clean && node build.mjs all",
    "build:umd-bundle": "node build.mjs umd-bundle",
    "watch:umd-bundle": "pnpm run build:umd-bundle && node build.mjs umd-bundle --watch",
    "build:esm-bundle": "node build.mjs esm-bundle",
    "watch:esm-bundle": "pnpm run build:esm-bundle && node build.mjs esm-bundle --watch",
    "watch": "node build.mjs all --watch",
    "prepublishOnly": "pnpm run build",
    "publish:npm": "pnpm run build && cp package.json package.json.back && pnpm pack && TARBALL_NAME=$(ls dooboostore-simple-web-component-*.tgz | head -n 1) && tar -xzf \"$TARBALL_NAME\" -C . --strip-components=1 package/package.json && rm \"$TARBALL_NAME\" && (pnpm publish --no-git-checks || true) && cp package.json.back package.json && rm -rf package.json.back  ",
    "ts:clean": "find . -name '*.js' -o -name '*.map' -o -name '*.d.ts' | xargs rm -f",
    "typecheck": "pnpm exec tsc --noEmit",
    "generate:is": "tsx generate-is.ts",
    "generate:is:watch": "node --import tsx --watch --watch-path=./src/elements/SwcIf.ts --watch-path=./src/elements/SwcLoop.ts --watch-path=./src/elements/SwcChoose.ts --watch-path=./src/elements/SwcAsync.ts --watch-path=./src/elements/SwcAppMixin.ts --watch-path=./generate-is.ts generate-is.ts",
    "test": "echo test",
    "test:bundle": "pnpm --filter @dooboostore/simple-web-component-bundle-test dev"
  }
}
